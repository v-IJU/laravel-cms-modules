{
  "name": "viju/laravel-cms-modules",
  "description": "Modular Laravel CMS with Tabler theme, menu.xml navigation — Laravel 9-12 compatible",
  "keywords": [
    "laravel",
    "cms",
    "modular",
    "admin",
    "tabler",
    "theme",
    "menu",
    "modules"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Viju",
      "email": "your@email.com"
    },
    {
      "name": "Ramesh (Original Author)",
      "email": "shunramit@gmail.com",
      "role": "Original developer"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
    "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0",
    "illuminate/console": "^9.0|^10.0|^11.0|^12.0",
    "illuminate/routing": "^9.0|^10.0|^11.0|^12.0",
    "illuminate/view": "^9.0|^10.0|^11.0|^12.0",
    "illuminate/database": "^9.0|^10.0|^11.0|^12.0",
    "prabowosd/laravel-collective-html": "^1.0|^1.1|^13.0",
    "spatie/laravel-permission": "^5.0|^6.0",
    "yajra/laravel-datatables-oracle": "^9.0|^10.0|^11.0|^12.0",
    "unisharp/laravel-filemanager": "^2.6|^2.9"
  },
  "require-dev": {
    "orchestra/testbench": "^7.0|^8.0|^9.0",
    "pestphp/pest": "^2.0|^3.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Ramesh\\Cms\\": "src/"
    },
    "files": [
      "src/Helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Ramesh\\Cms\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ramesh\\Cms\\CmsServiceProvider"
      ],
      "aliases": {
        "Cms": "Ramesh\\Cms\\Facades\\Cms"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
